{#- Section divider: lattice preset.
    River flowing through lattice — sinusoidal wave paths evoking the
    Juruena River, axis mundi of the Enawenê-Nawê cosmos, flowing
    through the woven waitiwina fishing dams. -#}
<svg viewBox="0 0 1200 28" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    {# Central spine — straight horizontal #}
    <line x1="0" y1="14" x2="1200" y2="14" stroke="var(--td-color-primary)" stroke-width="1.5" stroke-linecap="round" opacity="0.1"/>
    {# River waves — three parallel sinusoidal paths with different amplitudes #}
    <path d="M0,14 C100,6 200,22 300,14 C400,6 500,22 600,14 C700,6 800,22 900,14 C1000,6 1100,22 1200,14"
          fill="none" stroke="var(--td-color-primary)" stroke-width="2" stroke-linecap="round" opacity="0.15"/>
    <path d="M0,14 C100,9 200,19 300,14 C400,9 500,19 600,14 C700,9 800,19 900,14 C1000,9 1100,19 1200,14"
          fill="none" stroke="var(--td-color-accent, var(--td-color-primary))" stroke-width="1.5" stroke-linecap="round" opacity="0.12"/>
    <path d="M0,14 C150,10 250,18 400,14 C550,10 650,18 800,14 C950,10 1050,18 1200,14"
          fill="none" stroke="var(--td-color-primary)" stroke-width="1" stroke-linecap="round" opacity="0.08"/>
    {# Lattice cross marks — small diagonal crosses at wave intersections #}
    {% for x in [150, 300, 450, 600, 750, 900, 1050] %}
    <g stroke="var(--td-color-primary)" stroke-width="1.2" stroke-linecap="round" opacity="0.1">
        <line x1="{{ x - 4 }}" y1="10" x2="{{ x + 4 }}" y2="18"/>
        <line x1="{{ x + 4 }}" y1="10" x2="{{ x - 4 }}" y2="18"/>
    </g>
    {% endfor %}
</svg>
