<!DOCTYPE html>
<html lang="{{ t.html_lang | default(locale | default('en')) }}" class="no-js">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {% if theme.favicon %}
    <link rel="icon" href="{{ base_path | default('') }}{{ theme.favicon }}">
    {% endif %}
    <title>{% block title %}{{ title | default(site.title) }}{% endblock %} - {{ site.title }}</title>
    <link rel="stylesheet" href="{{ base_path | default('') }}css/fonts.css">
    <link rel="stylesheet" href="{{ base_path | default('') }}css/terradoc.css">
    <script>document.documentElement.classList.remove('no-js');document.documentElement.classList.add('js');</script>
    <style>
        :root {
            --td-color-primary: {{ theme.colors.primary | default('#3D352F') }};
            --td-color-accent: {{ theme.colors.accent | default('#B7522C') }};
            --td-color-accent-muted: {{ theme.colors.accent_muted | default('#9A4427') }};
            --td-color-bg: {{ theme.colors.bg | default('#F9F6F2') }};
            --td-color-bg-light: {{ theme.colors.bg_light | default('#F5EDE8') }};
            --td-color-bg-infobox: {{ theme.colors.bg_infobox | default('#FAF8F5') }};
            --td-color-border: {{ theme.colors.border | default('#E8E4DF') }};
            --td-color-border-dark: {{ theme.colors.border_dark | default('#C8B8A8') }};
            --td-color-text: {{ theme.colors.text | default('#333333') }};
            --td-color-text-muted: {{ theme.colors.text_muted | default('#6B6B6B') }};
            --td-color-highlight: {{ theme.colors.highlight | default('#fff59d') }};
            --td-color-warning-bg: {{ theme.colors.warning_bg | default('#fff8e1') }};
            --td-color-surface: {{ theme.colors.surface | default('#FFFFFF') }};
            --td-color-border-light: {{ theme.colors.border_light | default('#EEEEEE') }};
            --td-color-text-secondary: {{ theme.colors.text_secondary | default('#555555') }};
            --td-color-accent-light: {{ theme.colors.accent_light | default('#FDF0EB') }};
            --td-color-success: {{ theme.colors.success | default('#5B8C5A') }};
            --td-color-error: {{ theme.colors.error | default('#CC0000') }};
            --td-color-accent-ring: {{ theme.colors.accent_ring | default('rgba(183, 82, 44, 0.2)') }};
            --td-radius: {{ theme.border_radius | default('28px') }};
            --td-color-dark: {{ theme.colors.dark | default('#0B0F17') }};
            --td-radius-lg: {{ theme.border_radius | default('28px') }};
            --td-radius-pill: 999px;
            --td-font-family: {{ theme.font_family | default("'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif") }};
            --td-font-headings: {{ theme.font_family_headings | default("'Sora', 'Inter', sans-serif") }};
            --td-font-mono: {{ theme.font_family_mono | default("'IBM Plex Mono', 'Consolas', monospace") }};
            --td-term-color: {{ theme.term_color or theme.colors.accent_muted | default('#A85D33') }};
            --td-term-weight: {{ theme.term_weight | default('600') }};
            --td-color-gold: {{ theme.colors.gold | default('#D4A03A') }};
        }
        {% if theme.colors_dark %}
        @media (prefers-color-scheme: dark) {
            :root {
                --td-color-primary: {{ theme.colors_dark.primary }};
                --td-color-accent: {{ theme.colors_dark.accent }};
                --td-color-accent-muted: {{ theme.colors_dark.accent_muted }};
                --td-color-bg: {{ theme.colors_dark.bg }};
                --td-color-bg-light: {{ theme.colors_dark.bg_light }};
                --td-color-bg-infobox: {{ theme.colors_dark.bg_infobox }};
                --td-color-border: {{ theme.colors_dark.border }};
                --td-color-border-dark: {{ theme.colors_dark.border_dark }};
                --td-color-text: {{ theme.colors_dark.text }};
                --td-color-text-muted: {{ theme.colors_dark.text_muted }};
                --td-color-highlight: {{ theme.colors_dark.highlight }};
                --td-color-warning-bg: {{ theme.colors_dark.warning_bg }};
                --td-color-surface: {{ theme.colors_dark.surface }};
                --td-color-border-light: {{ theme.colors_dark.border_light }};
                --td-color-text-secondary: {{ theme.colors_dark.text_secondary }};
                --td-color-accent-light: {{ theme.colors_dark.accent_light }};
                --td-color-success: {{ theme.colors_dark.success }};
                --td-color-error: {{ theme.colors_dark.error }};
                --td-color-accent-ring: {{ theme.colors_dark.accent_ring }};
            }
        }
        {% endif %}
        {% block extra_styles %}{% endblock %}
    </style>
</head>
<body class="td-style-{{ theme.style | default('terra') }}">
    <a href="#main-content" class="skip-link">{{ t.skip_link | default('Pular para conteúdo') }}</a>

    {% set np = nav_prefix | default('') %}
    <nav id="td-nav" aria-label="{{ t.nav_label | default('Navegação principal') }}">
        <div class="td-nav-inner">
            <a href="{{ np }}index.html" class="brand">
                {% if theme.logo %}
                <img src="{{ base_path | default('') }}{{ theme.logo }}" alt="" class="brand-logo">
                {% else %}
                <span class="td-logo-mark" aria-hidden="true"><span class="ring-outer"><span class="ring-inner"><span class="ring-dot"></span></span></span></span>
                {% endif %}
                <span>{{ t.nav_brand | default(site.title) }}</span>
            </a>
            <button class="nav-toggle" aria-label="{{ t.nav_menu_label | default('Menu') }}" aria-expanded="false">&#9776;</button>
            <div class="nav-links">
                {% for mod in modules %}
                <a href="{{ np }}{{ mod.slug }}.html"{% if page == mod.slug %} class="active" aria-current="page"{% endif %}>{{ t['nav_' + mod.slug] | default(mod.name) }}</a>
                {% endfor %}
            </div>
            {% if locale_switches and locale_switches | length > 1 %}
            <div class="lang-switch" aria-label="{{ t.lang_switch_label | default('Language selector') }}">
                {% for switch in locale_switches %}
                    {% if not loop.first %}<span class="lang-sep">/</span>{% endif %}
                    {% if switch.is_current %}
                    <span class="lang-current" aria-current="true">{{ switch.code | default(switch.label) | upper }}</span>
                    {% else %}
                    <a href="{{ switch.href }}" class="lang-link">{{ switch.code | default(switch.label) | upper }}</a>
                    {% endif %}
                {% endfor %}
            </div>
            {% endif %}
        </div>
    </nav>

    <main id="main-content" class="td-container">
        {% block content %}{% endblock %}
    </main>

    <footer>
        <div class="footer-adugo-spine" aria-hidden="true">
            <svg viewBox="0 0 1200 28" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
                <line x1="0" y1="14" x2="1200" y2="14" stroke="var(--td-color-primary)" stroke-width="2" stroke-linecap="round" opacity="0.15"/>
                <g stroke="var(--td-color-primary)" stroke-linecap="round" opacity="0.12">
                    <line x1="45" y1="5" x2="45" y2="23" stroke-width="2.5"/>
                    <line x1="68" y1="7" x2="68" y2="21" stroke-width="3.5"/>
                    <line x1="105" y1="3" x2="105" y2="25" stroke-width="2"/>
                    <line x1="120" y1="8" x2="120" y2="20" stroke-width="4"/>
                    <line x1="160" y1="6" x2="160" y2="22" stroke-width="2.8"/>
                    <line x1="195" y1="4" x2="195" y2="24" stroke-width="3.2"/>
                    <line x1="265" y1="5" x2="265" y2="23" stroke-width="3"/>
                    <line x1="298" y1="3" x2="298" y2="25" stroke-width="3.8"/>
                    <line x1="335" y1="8" x2="335" y2="20" stroke-width="3.5"/>
                    <line x1="372" y1="6" x2="372" y2="22" stroke-width="4"/>
                    <line x1="408" y1="7" x2="408" y2="21" stroke-width="3.2"/>
                    <line x1="468" y1="3" x2="468" y2="25" stroke-width="3.5"/>
                    <line x1="498" y1="1" x2="498" y2="27" stroke-width="4.2"/>
                    <line x1="528" y1="7" x2="528" y2="21" stroke-width="3.8"/>
                    <line x1="558" y1="2" x2="558" y2="26" stroke-width="3.2"/>
                    <line x1="590" y1="1" x2="590" y2="27" stroke-width="2.5"/>
                    <line x1="615" y1="3" x2="615" y2="25" stroke-width="2.2"/>
                    <line x1="645" y1="2" x2="645" y2="26" stroke-width="3"/>
                    <line x1="672" y1="4" x2="672" y2="24" stroke-width="3.5"/>
                    <line x1="705" y1="3" x2="705" y2="25" stroke-width="3.8"/>
                    <line x1="738" y1="1" x2="738" y2="27" stroke-width="4"/>
                    <line x1="790" y1="4" x2="790" y2="24" stroke-width="2.5"/>
                    <line x1="828" y1="3" x2="828" y2="25" stroke-width="2.8"/>
                    <line x1="865" y1="8" x2="865" y2="20" stroke-width="2.2"/>
                    <line x1="900" y1="6" x2="900" y2="22" stroke-width="2.6"/>
                    <line x1="980" y1="4" x2="980" y2="24" stroke-width="3.5"/>
                    <line x1="1040" y1="6" x2="1040" y2="22" stroke-width="3.8"/>
                    <line x1="1095" y1="7" x2="1095" y2="21" stroke-width="3.5"/>
                    <line x1="1160" y1="9" x2="1160" y2="19" stroke-width="4"/>
                </g>
            </svg>
        </div>
        <div class="td-container">
            <div class="footer-grid">
                <div class="footer-brand-col">
                    <a href="{{ np }}index.html" class="brand" style="color:white;text-decoration:none;font-family:var(--td-font-headings);font-weight:700;font-size:1.15rem;display:inline-flex;align-items:center;gap:0.6rem;">
                        {% if theme.logo %}
                        <img src="{{ base_path | default('') }}{{ theme.logo }}" alt="" class="brand-logo" style="width:56px;height:56px;">
                        {% else %}
                        <span class="td-logo-mark" aria-hidden="true" style="--td-color-primary:#fff;"><span class="ring-outer"><span class="ring-inner"><span class="ring-dot"></span></span></span></span>
                        {% endif %}
                        {{ t.nav_brand | default(site.title) }}
                    </a>
                    <p class="footer-brand-desc">{{ t.footer_description | default('') }}</p>
                </div>
                <div>
                    <h4 class="footer-heading">{{ t.footer_nav_heading | default('Navigation') }}</h4>
                    <ul class="footer-links">
                        {% for mod in modules %}
                        <li><a href="{{ np }}{{ mod.slug }}.html">{{ t['nav_' + mod.slug] | default(mod.name) }}</a></li>
                        {% endfor %}
                    </ul>
                </div>
                <div>
                    <h4 class="footer-heading">{{ t.footer_contact_heading | default('Contact') }}</h4>
                    {% if t.footer_email %}
                    <div class="footer-contact-item">
                        <span class="footer-contact-icon">&#9993;</span>
                        <a href="mailto:{{ t.footer_email }}">{{ t.footer_email }}</a>
                    </div>
                    {% endif %}
                    {% if t.footer_location %}
                    <div class="footer-contact-item">
                        <span class="footer-contact-icon">&#9906;</span>
                        <span>{{ t.footer_location }}</span>
                    </div>
                    {% endif %}
                </div>
            </div>
            <div class="footer-bottom">
                <p>{{ t.footer_generated | default('Generated with') }} <a href="https://pypi.org/project/terradoc/">terradoc</a>, <a href="https://pypi.org/project/aptoro/">aptoro</a> &amp; <a href="https://pypi.org/project/kodudo/">kodudo</a></p>
                <p>{{ t.footer_license | default('') }}</p>
            </div>
        </div>
    </footer>

    <script src="{{ base_path | default('') }}js/common.js"></script>
    {% block scripts %}{% endblock %}
</body>
</html>
